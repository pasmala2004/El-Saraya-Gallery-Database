# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
APP_NAME=ERP Backend
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full async SQLAlchemy connection string (used directly by the app)
DATABASE_URL=postgresql+asyncpg://erp_user:erp_password@db:5432/erp_db

# Sync connection string (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg://erp_user:erp_password@db:5432/erp_db

# ------------------------------------------------------------------
# Uvicorn / Server
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
