{
  "specId": "projects-module-redesign",
  "name": "Projects Module Redesign",
  "description": "Transform Projects into the central operational workspace of the ERP system",
  "type": "feature",
  "status": "requirements-approved",
  "priority": "high",
  "estimatedEffort": "60-80 hours",
  "created": "2026-07-21",
